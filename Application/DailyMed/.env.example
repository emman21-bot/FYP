# DailyMed backend environment example
# Copy this file to .env and fill in your actual values.

# MongoDB connection
MONGO_URI=mongodb://localhost:27017/dailymed

# Server port
PORT=5000

# Node environment
NODE_ENV=development

# SMTP / email settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=your-email@gmail.com

# Optional email fallback names (supporting legacy variable names)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# Redis + queue (optional)
USE_EMAIL_QUEUE=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# OTP expiration (seconds)
OTP_EXPIRE_SECONDS=600

# S3 / MinIO storage (optional)
STORAGE_PROVIDER=local # options: local | s3 | minio
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT= # e.g. http://127.0.0.1:9000 for MinIO
S3_FORCE_PATH_STYLE=true

# Push notification provider keys
FCM_SERVER_KEY=your-fcm-server-key

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Optional frontend overrides for Expo environment
# When using ngrok or remote API URL, set API_BASE_URL instead of hardcoded local IP.
API_BASE_URL=https://your-ngrok-url.ngrok-free.dev
API_ENV=ngrok

# Frontend only values (Expo extra config can also be used)
EXPO_PUBLIC_API_ENV=development
EXPO_PUBLIC_API_BASE_URL=http://192.168.1.71:5000/api
